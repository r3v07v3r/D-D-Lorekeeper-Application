{
  "name": "lorekeeper-electron",
  "version": "1.2.0",
  "private": true,
  "description": "Lorekeeper desktop shell: spawns the bundled Python backend and loads the React dashboard.",
  "author": "R3v07v3R",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@achingbrain/nat-port-mapper": "^4.0.5",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.lorekeeper.app",
    "productName": "Lorekeeper",
    "asar": true,
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": [
          "lorekeeper-backend*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "R3v07v3R",
        "repo": "D-D-Lorekeeper-Application",
        "releaseType": "release"
      }
    ]
  }
}
