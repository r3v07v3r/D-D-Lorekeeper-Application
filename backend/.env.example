# Copy to .env and fill in. Never commit the real .env.

# Discord bot token from the Discord Developer Portal. Leave blank to run the
# backend without starting the Discord bot (useful for API-only development).
DISCORD_BOT_TOKEN=

DATABASE_URL=sqlite:///./lorekeeper.db

# Where per-user recording chunks are written. Created if missing.
AUDIO_STORAGE_DIR=./recordings

# How often (minutes) the recorder flushes the current in-memory WaveSink to
# disk and starts a fresh one, so a multi-hour session never holds more than
# one chunk's worth of raw PCM per user in memory (risk #4).
RECORDING_CHUNK_MINUTES=5

# Comma-separated list of allowed CORS origins.
# NOTE (risk #8, verified during Phase 5): Electron pages loaded via file://
# send a literal "Origin: null" header, not "file://". Confirmed against this
# backend's CORSMiddleware: without "null" in this list, every authenticated
# request is rejected client-side (Authorization header forces a CORS
# preflight, which 400s) even though it looks fine from curl. "null" is
# required for the packaged app to work, not just the Vite dev origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null

# OpenAI API key, used for both Whisper transcription and GPT-4o summarization.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
SUMMARIZATION_MODEL=gpt-4o

# How often (minutes) the backend re-fetches character data from D&D Beyond
# for every registered player with a dnd_beyond_character_id set.
DNDBEYOND_SYNC_INTERVAL_MINUTES=15
